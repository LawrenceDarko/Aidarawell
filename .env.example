# =============================================================================
# JUMPSTART - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
#
# Instructions: https://github.com/yourusername/jumpstart/docs/GETTING_STARTED.md
# =============================================================================

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
# The public URL where your app is hosted
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NEXTAUTH AUTHENTICATION
# -----------------------------------------------------------------------------
# CRITICAL: Must be at least 15 characters long
# Generate with: openssl rand -base64 32
# NEVER share or commit this value
NEXTAUTH_SECRET=your-super-secret-key-minimum-15-characters-here

# The base URL for authentication callbacks
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE (Choose ONE option below)
# -----------------------------------------------------------------------------

# Option 1: MongoDB
# Connection string format: mongodb://[username:password@]host[:port]/database
# MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/jumpstart

# Option 2: Supabase
# Get these from: https://app.supabase.com/project/_/settings/api
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   - http://localhost:3000/api/auth/callback/google (development)
#   - https://yourdomain.com/api/auth/callback/google (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS
# -----------------------------------------------------------------------------
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use TEST mode keys for development (sk_test_... and pk_test_...)
# Use LIVE mode keys for production (sk_live_... and pk_live_...)

# Secret key (server-side only - NEVER expose to client)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Publishable key (safe for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook signing secret
# Get this from: https://dashboard.stripe.com/webhooks
# For local testing, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Pricing Plan IDs
# Create products and prices in Stripe Dashboard: https://dashboard.stripe.com/products
# Then copy the Price IDs here (format: price_xxxxxxxxxxxxx)
STRIPE_STARTER_PRICE_ID=price_your_starter_plan_id
STRIPE_PRO_PRICE_ID=price_your_pro_plan_id
# Add more plan IDs as needed
# STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_plan_id

# -----------------------------------------------------------------------------
# EMAIL SERVICE (Choose ONE option below)
# -----------------------------------------------------------------------------

# Option 1: Resend (Recommended)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Option 2: Mailgun (Alternative)
# Get credentials from: https://app.mailgun.com/app/account/security/api_keys
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mg.yourdomain.com

# Email addresses
EMAIL_FROM=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com

# -----------------------------------------------------------------------------
# ANALYTICS (Optional)
# -----------------------------------------------------------------------------
# Google Analytics 4
# Get Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# ERROR TRACKING (Optional but Recommended)
# -----------------------------------------------------------------------------
# Sentry DSN
# Get from: https://sentry.io/settings/projects/your-project/keys/
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features
ENABLE_MAGIC_LINKS=true
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true

# Dark Mode
# Set to 'true' to enable dark mode feature
# When enabled, users can toggle between light and dark themes
NEXT_PUBLIC_DARK_MODE=true

# -----------------------------------------------------------------------------
# DEVELOPMENT OPTIONS (Development Only)
# -----------------------------------------------------------------------------
# Set to 'true' to disable rate limiting during development
# NEVER set to true in production
# DISABLE_RATE_LIMIT=false

# Enable debug logging
# NODE_ENV=development

# -----------------------------------------------------------------------------
# PRODUCTION OPTIONS (Production Only)
# -----------------------------------------------------------------------------
# Set to 'production' for production environment
# NODE_ENV=production

# Database connection pool size (optional)
# DB_POOL_SIZE=10

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. SECURITY: Never commit .env.local to version control
# 2. MINIMUM LENGTH: NEXTAUTH_SECRET must be at least 15 characters
# 3. TEST MODE: Use Stripe test mode (sk_test_/pk_test_) during development
# 4. DOMAINS: Update all URLs when deploying to production
# 5. WEBHOOKS: Configure production webhook endpoint in Stripe Dashboard
# 6. VERIFICATION: Verify email sender domain with Resend/Mailgun before sending
# 
# For detailed setup instructions, visit:
# https://github.com/yourusername/jumpstart/docs/GETTING_STARTED.md
# =============================================================================
